root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
tab_width = 4
trim_trailing_whitespace = true

[*.{kt,kts}]
indent_style = space
indent_size = 4
ktlint_code_style = ktlint_official
max_line_length = 120
tab_width = 4

[*.{js,mjs,cjs,jsx,ts,tsx}]
indent_size = 4
tab_width = 4

[*.swift]
indent_size = 4
max_line_length = 120
tab_width = 4

[*.md]
trim_trailing_whitespace = false

[Makefile*]
indent_style = tab
indent_size = 4
tab_width = 4

[*.mk]
indent_style = tab
indent_size = 4
tab_width = 4
